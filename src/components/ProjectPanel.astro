---
import type { Project } from "../data/projects";

interface Props {
    project: Project;
    variant?: "preview" | "full";
}

const { project, variant = "full" } = Astro.props;
const isPreview = variant === "preview";

const detailItems = isPreview
    ? [
        {
            label: "Valor entregado",
            value: project.result,
        },
    ]
    : [
        {
            label: "Reto",
            value: project.challenge,
        },
        {
            label: "Solución",
            value: project.solution,
        },
        {
            label: "Resultado",
            value: project.result,
        },
    ];
---

<article
    class="group flex h-full flex-col overflow-hidden border-2 border-black bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-transform duration-300 ease-out hover:-translate-y-2 hover:translate-x-2"
>
    <div
        class="flex items-start justify-between gap-4 border-b-2 border-black bg-gray-50 px-5 py-4 md:px-6"
    >
        <div>
            <p
                class="font-mono text-[10px] uppercase tracking-[0.3em] text-gray-500"
            >
                [ {project.category} ]
            </p>
            <h3
                class="mt-2 text-2xl font-bold uppercase tracking-tight break-words leading-tight md:text-3xl"
            >
                {project.title}
            </h3>
        </div>

        <span class="font-mono text-xs font-bold uppercase tracking-widest">
            {project.year}
        </span>
    </div>

    <div class="grid h-full grid-cols-1 md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
        <div
            class="relative min-h-[240px] border-b-2 border-black bg-gray-100 md:min-h-full md:border-b-0 md:border-r-2"
        >
            {
                project.image ? (
                    <img
                        src={project.image}
                        alt={`Vista previa del proyecto ${project.title}`}
                        class="absolute inset-0 h-full w-full object-cover transition-all duration-500 group-hover:scale-[1.02]"
                        loading="lazy"
                        decoding="async"
                    />
                ) : (
                    <div class="absolute inset-0 overflow-hidden bg-[#f5f5f5]">
                        <div
                            class="absolute inset-0 bg-[radial-gradient(#d1d5db_1px,transparent_1px)] [background-size:18px_18px]"
                        >
                        </div>
                        <div class="absolute inset-x-0 top-0 h-20 bg-gradient-to-b from-white to-transparent">
                        </div>
                        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-6 text-center">
                            <span
                                class="font-black text-5xl uppercase tracking-tight text-gray-200 md:text-6xl"
                            >
                                {project.year}
                            </span>
                            <p
                                class="font-mono text-[11px] uppercase tracking-[0.3em] text-gray-500"
                            >
                                Vista previa próximamente
                            </p>
                        </div>
                    </div>
                )
            }
        </div>

        <div class="flex h-full flex-col gap-6 p-6 md:p-8">
            <p class="text-sm font-medium leading-relaxed text-gray-600 md:text-base">
                {project.summary}
            </p>

            <div
                class:list={[
                    "grid gap-4",
                    isPreview ? "grid-cols-1" : "grid-cols-1 lg:grid-cols-3",
                ]}
            >
                {
                    detailItems.map((item) => (
                        <div class="border border-black/10 bg-gray-50 p-4">
                            <p
                                class="font-mono text-[10px] uppercase tracking-[0.3em] text-gray-500"
                            >
                                {item.label}
                            </p>
                            <p class="mt-3 text-sm leading-relaxed text-gray-700">
                                {item.value}
                            </p>
                        </div>
                    ))
                }
            </div>

            <div class="mt-auto flex flex-col gap-5">
                <div class="flex flex-wrap gap-2">
                    {
                        project.technologies.map((technology) => (
                            <span
                                class="border border-black px-3 py-1 text-[10px] font-mono font-bold uppercase tracking-[0.2em] text-black"
                            >
                                {technology}
                            </span>
                        ))
                    }
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-sm text-gray-500">
                        Caso compacto para mostrar enfoque, stack y capacidad de entrega.
                    </p>

                    <a
                        href={project.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex min-h-11 items-center justify-center border-2 border-black px-5 py-3 text-center font-mono text-xs uppercase tracking-[0.2em] transition-colors hover:bg-black hover:text-white"
                    >
                        {project.linkLabel}
                    </a>
                </div>
            </div>
        </div>
    </div>
</article>
