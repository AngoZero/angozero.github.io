---
import { technologyCategories } from "../../data/technologies";

const mainTechs = ["React", "TypeScript", "Astro", "Node.js", "Laravel", "Tailwind", "Next.js", "FastAPI"];
const allSkills = technologyCategories.flatMap((c) => c.skills);
const featured = allSkills.filter((s) => mainTechs.includes(s.name));
---

<section
    id="stack"
    class="relative py-32 px-6 bg-white text-black border-t border-black overflow-hidden"
>
    <div
        class="absolute inset-0 z-0 h-full w-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:24px_24px]"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto">
        <div class="mb-20 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.8fr)] lg:items-end">
            <div class="fade-in-up">
                <p class="text-xs font-mono text-gray-500 uppercase tracking-widest">
                    [ Stack ]
                </p>
                <h2
                    class="mt-6 font-black text-[clamp(2.5rem,10vw,8rem)] leading-[0.85] tracking-tighter uppercase break-words"
                >
                    Stack
                    <span
                        class="block text-transparent bg-clip-text bg-gradient-to-b from-gray-700 via-gray-500 to-gray-400"
                    >
                        tecnológico
                    </span>
                </h2>
            </div>
            <p class="fade-in-up text-sm font-medium leading-relaxed text-gray-600 md:text-base">
                Estas son las herramientas principales con las que trabajo. Elijo stack según
                el problema, no por moda.
            </p>
        </div>

        <!-- Featured: las principales con icono -->
        <div class="fade-in-up grid grid-cols-2 sm:grid-cols-4 gap-4 mb-16">
            {featured.map((tech) => (
                <div class="group border-2 border-black bg-white p-5 flex items-center gap-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-all duration-300 ease-out hover:-translate-y-1 hover:translate-x-1">
                    <img
                        src={tech.icon}
                        alt={tech.name}
                        class="w-8 h-8 object-contain grayscale group-hover:grayscale-0 transition-all duration-300"
                        loading="lazy"
                    />
                    <span class="font-mono text-xs font-bold uppercase tracking-widest">
                        {tech.name}
                    </span>
                </div>
            ))}
        </div>

        <!-- Resto agrupado por categoría como chips -->
        <div class="fade-in-up">
            <details class="group">
                <summary class="cursor-pointer font-mono text-xs uppercase tracking-widest text-gray-500 hover:text-black transition-colors flex items-center gap-3 mb-6">
                    <span class="h-[2px] w-8 bg-current"></span>
                    Ver stack completo
                    <span class="transition-transform duration-300 group-open:rotate-180">&#9662;</span>
                </summary>

                <div class="flex flex-col gap-8 pt-4 border-t border-black/10">
                    {technologyCategories.map((category) => (
                        <div>
                            <h3 class="font-mono text-[10px] uppercase tracking-[0.3em] text-gray-500 mb-3">
                                {category.title}
                            </h3>
                            <div class="flex flex-wrap gap-2">
                                {category.skills.map((tech) => (
                                    <span class="border border-black px-3 py-1.5 font-mono text-[10px] font-bold uppercase tracking-[0.15em] hover:bg-black hover:text-white transition-colors">
                                        {tech.name}
                                    </span>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </details>
        </div>
    </div>
</section>
