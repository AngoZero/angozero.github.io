---
import { site } from "../../data/site";
const currentYear = new Date().getFullYear();
---

<footer class="border-t-2 border-black bg-white py-16 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            <!-- Columna 1: Información -->
            <div>
                <h3 class="font-black text-2xl uppercase tracking-tight mb-4">
                    {site.name}
                </h3>
                <p class="text-gray-600 text-sm mb-2">
                    <strong class="text-black">{site.realName}</strong>
                </p>
                <p class="text-gray-600 text-sm">
                    Desarrollador Fullstack Freelance<br />
                    México
                </p>
            </div>

            <!-- Columna 2: Enlaces -->
            <div>
                <h4 class="font-bold uppercase tracking-wide text-sm mb-4">
                    Navegación
                </h4>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="/#services"
                            class="text-gray-600 hover:text-black transition-colors"
                        >
                            Servicios
                        </a>
                    </li>
                    <li>
                        <a
                            href="/#portfolio"
                            class="text-gray-600 hover:text-black transition-colors"
                        >
                            Portafolio
                        </a>
                    </li>
                    <li>
                        <a
                            href="/#stack"
                            class="text-gray-600 hover:text-black transition-colors"
                        >
                            Stack
                        </a>
                    </li>
                    <li>
                        <a
                            href="/#process"
                            class="text-gray-600 hover:text-black transition-colors"
                        >
                            Proceso
                        </a>
                    </li>
                    <li>
                        <a
                            href="/#faq"
                            class="text-gray-600 hover:text-black transition-colors"
                        >
                            FAQ
                        </a>
                    </li>
                    <li>
                        <a
                            href="/#contact"
                            class="text-gray-600 hover:text-black transition-colors"
                        >
                            Contacto
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Columna 3: Legal y Redes -->
            <div>
                <h4 class="font-bold uppercase tracking-wide text-sm mb-4">
                    Legal y Social
                </h4>
                <ul class="space-y-2 text-sm mb-6">
                    <li>
                        <a
                            href="/portafolio"
                            class="text-gray-600 hover:text-black transition-colors font-medium"
                        >
                            Ver portafolio
                        </a>
                    </li>
                    <li>
                        <a
                            href="/privacidad"
                            class="text-gray-600 hover:text-black transition-colors font-medium"
                        >
                            Política de Privacidad
                        </a>
                    </li>
                </ul>

            </div>
        </div>

        <!-- Separador -->
        <div class="border-t border-black pt-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-xs font-mono text-gray-500 text-center md:text-left">
                    © {currentYear} {site.realName} ({site.name}). Todos los derechos reservados.
                </p>

                <div class="flex items-center gap-2">
                    <span class="text-xs font-mono text-gray-500">
                        Hecho con
                    </span>
                    <a
                        href="https://astro.build"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs font-mono text-gray-600 hover:text-black transition-colors font-bold"
                    >
                        Astro
                    </a>
                    <span class="text-xs font-mono text-gray-500">+</span>
                    <a
                        href="https://tailwindcss.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs font-mono text-gray-600 hover:text-black transition-colors font-bold"
                    >
                        Tailwind
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>
