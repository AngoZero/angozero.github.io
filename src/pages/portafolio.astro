---
import ProjectPanel from "../components/ProjectPanel.astro";
import Footer from "../components/sections/Footer.astro";
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";
import { site } from "../data/site";

const title = `Portafolio | ${site.name}`;
const description =
    "Casos compactos del trabajo de AngoZero: desarrollo de software, landing pages y soluciones digitales con enfoque en ejecución y claridad técnica.";
---

<Layout title={title} description={description}>
    <section
        class="relative overflow-hidden border-b border-black bg-white px-6 pb-16 pt-10 text-black md:pb-20 md:pt-14"
    >
        <div
            class="absolute inset-0 z-0 h-full w-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:24px_24px]"
        >
        </div>

        <div class="relative z-10 mx-auto max-w-7xl">
            <div class="mb-12 flex flex-wrap justify-end gap-3 pt-14">
                <a
                    href="/#services"
                    class="inline-flex min-h-11 items-center justify-center border border-black px-4 py-2 text-center font-mono text-[11px] uppercase tracking-[0.2em] transition-colors hover:bg-black hover:text-white"
                >
                    Servicios
                </a>
                <a
                    href="/#contact"
                    class="inline-flex min-h-11 items-center justify-center border border-black px-4 py-2 text-center font-mono text-[11px] uppercase tracking-[0.2em] transition-colors hover:bg-black hover:text-white"
                >
                    Contacto
                </a>
            </div>

            <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.8fr)] lg:items-end">
                <div>
                    <p class="text-xs font-mono uppercase tracking-widest text-gray-500">
                        [ Portafolio ]
                    </p>
                    <h1
                        class="mt-6 font-black text-[clamp(2.8rem,9vw,7rem)] leading-[0.82] tracking-tighter uppercase"
                    >
                        <span class="block">Casos que</span>
                        <span
                            class="block text-transparent bg-clip-text bg-gradient-to-b from-gray-700 via-gray-500 to-gray-400"
                        >
                            demuestran
                        </span>
                        <span class="block text-transparent bg-clip-text bg-gradient-to-b from-gray-700 via-gray-500 to-gray-400">
                            valor
                        </span>
                    </h1>
                </div>

                <div class="max-w-xl">
                    <p class="text-sm font-medium leading-relaxed text-gray-600 md:text-base">
                        Aquí concentro proyectos que muestran cómo abordo retos de producto,
                        estructura técnica y ejecución visual. La idea no es llenar una galería,
                        sino enseñar con claridad el tipo de trabajo que puedo resolver.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="border-b border-black bg-white px-6 py-16 text-black md:py-20">
        <div class="mx-auto flex max-w-7xl flex-col gap-8">
            {
                projects.map((project, index) => (
                    <div class="fade-in-up" style={`transition-delay: ${index * 120}ms`}>
                        <ProjectPanel project={project} />
                    </div>
                ))
            }
        </div>
    </section>

    <section class="border-b border-black bg-white px-6 py-16 text-black md:py-20">
        <div class="mx-auto max-w-5xl border-2 border-black bg-white p-8 text-center shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] md:p-10">
            <p class="text-xs font-mono uppercase tracking-widest text-gray-500">
                [ ¿Tienes una idea o necesidad concreta? ]
            </p>
            <h2
                class="mt-6 font-black text-[clamp(2.2rem,8vw,5rem)] leading-[0.9] tracking-tighter uppercase"
            >
                Convirtamos eso en
                <span
                    class="block text-transparent bg-clip-text bg-gradient-to-b from-gray-700 via-gray-500 to-gray-400"
                >
                    un proyecto claro
                </span>
            </h2>
            <p class="mx-auto mt-6 max-w-2xl text-sm font-medium leading-relaxed text-gray-600 md:text-base">
                Si ya viste el tipo de trabajo que hago, el siguiente paso es revisar tu
                contexto y aterrizar una propuesta realista de alcance, tiempos y costo.
            </p>
            <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a
                    href="/#contact"
                    class="inline-flex min-h-11 items-center justify-center border-2 border-black bg-black px-6 py-3 text-center font-mono text-xs uppercase tracking-[0.2em] text-white transition-colors hover:bg-white hover:text-black"
                >
                    Ir a contacto
                </a>
                <a
                    href="/#stack"
                    class="inline-flex min-h-11 items-center justify-center border-2 border-black px-6 py-3 text-center font-mono text-xs uppercase tracking-[0.2em] transition-colors hover:bg-black hover:text-white"
                >
                    Ver stack tecnológico
                </a>
            </div>
        </div>
    </section>

    <Footer />
</Layout>
